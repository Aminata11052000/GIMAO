# ============================================================
# Fichier .env.prod.example — Copier en .env.prod et remplir
# ============================================================

# --- Base de données MariaDB ---
MYSQL_ROOT_PASSWORD=motdepasse_root_fort
MYSQL_DATABASE=gimao
MYSQL_USER=gimao_user
MYSQL_PASSWORD=motdepasse_db_fort

# --- Django ---
SECRET_KEY=remplacer_par_une_cle_secrete_longue_et_aleatoire

# --- Superutilisateur Django (créé automatiquement au démarrage) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=motdepasse_admin_fort
DJANGO_SUPERUSER_EMAIL=admin@exemple.fr
