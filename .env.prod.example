# Fichier d'exemple pour la configuration de production.
# Copier ce fichier en .env.prod et renseigner chaque valeur.
# Ne jamais versionner .env.prod — il contient des secrets.

# ------------------------------------------------------------
# Django
# ------------------------------------------------------------

# Clé secrète Django. Doit être unique et aléatoire en production.
# Générer avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Désactiver le mode debug en production (ne jamais mettre True en prod).
DEBUG=False

# Hôtes autorisés, séparés par des virgules.
# En production derrière Nginx sur la même machine : localhost suffit.
# Si l'application est exposée sur un domaine ou une IP publique, l'ajouter ici.
# Exemple : ALLOWED_HOSTS=localhost,127.0.0.1,mon-domaine.fr
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------
# Base de données MariaDB
# ------------------------------------------------------------

MYSQL_DATABASE=gimao
MYSQL_USER=gimao_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ------------------------------------------------------------
# Compte Django Admin
# Créé automatiquement au premier démarrage du conteneur backend.
# ------------------------------------------------------------

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@example.com
